# Скопируй в backend/.env и подставь свои значения.

# Локальная разработка: PostgreSQL на ноутбуке.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tetris

# Подпись JWT-токенов. На сервере заменить на длинную случайную строку.
SECRET_KEY=dev-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Путь к файлу-выгрузке Jira (временный источник вместо живого вебхука).
JIRA_SAMPLE_FILE=../response_example.json

# Живая Jira (понадобится только на этапе 12; при разработке можно не заполнять).
JIRA_BASE_URL=https://jira.askona.ru
JIRA_TOKEN=
